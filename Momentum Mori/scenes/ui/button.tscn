shader_parameter/color_stripe = Color(1, 0, 0, 1)
shader_parameter/divisions = 8.0
shader_parameter/stripe_bias = 2.5
shader_parameter/speed = 0.1
shader_parameter/angle = 2.785
shader_parameter/skew = 0.0

